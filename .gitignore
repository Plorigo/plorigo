# ============================================================
# Plorigo .gitignore
# ============================================================

# ---- Private / local context (NEVER commit) ----
.context/
.env
.env.*
!.env.example
*.local
# Anchored to the repo root: a top-level local credentials dir. WITHOUT the leading
# slash this also matches the internal/secrets Go module and hides it from git.
/secrets/
*.pem
*.key
*.p12
*-credentials.json

# ---- Go ----
/bin/
/dist/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage.txt
coverage.html
profile.cov
go.work
go.work.sum
/vendor/

# ---- Node / Frontend (apps/web) ----
node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions
build/
.vite/
.turbo/
*.tsbuildinfo
.eslintcache
.cache/

# ---- Generated code ----
# Protobuf / ConnectRPC output (buf generate) — regenerated via `make generate`.
/proto/gen/
apps/web/src/gen/
# sqlc output (internal/platform/database/db) IS committed — do not ignore it.

# ---- Dashboard build output ----
apps/web/dist/
# Copied from apps/web/dist by `make build-embed` for the embedded single binary.
internal/platform/web/dist/

# ---- Local infra / Docker ----
.docker-data/
*.tar.gz
*.tgz

# ---- Logs ----
*.log
# Anchored to the repo root so it ignores a top-level runtime logs dir but not the
# planned internal/logs module (same trap as /secrets/ above). *.log still catches
# stray log files anywhere.
/logs/

# ---- Editors / OS ----
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
.DS_Store
Thumbs.db

# ---- Agent/CLI runtime artifacts (committed config like .claude/settings.json is fine) ----
.claude/*.lock
