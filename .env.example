# Copy to .env and fill in. NEVER commit a real .env (see .gitignore).

# 32-byte key, base64-encoded. Generate with: openssl rand -base64 32
APP_MASTER_KEY=

# PostgreSQL connection string used by the control plane and goose migrations.
DATABASE_URL=postgres://plorigo:plorigo@localhost:5432/plorigo?sslmode=disable

# HTTP port the control plane listens on.
PORT=8080

# "production" makes session cookies Secure (HTTPS-only). Anything else = dev.
PLORIGO_ENV=dev

# Dashboard origin used to build links in emails (verification, password reset).
# In dev the dashboard runs on the Vite server; in the single binary it is the
# control plane's own public URL.
PLORIGO_BASE_URL=http://localhost:5173

# Auth policy. Open registration lets anyone sign up; when false only the first
# (bootstrap) user and invited users may. Email verification is optional.
PLORIGO_ALLOW_OPEN_REGISTRATION=true
PLORIGO_REQUIRE_EMAIL_VERIFICATION=false

# SMTP for transactional email. Leave SMTP_HOST empty to log emails (with their
# links) instead of sending — fine for local/self-host without a mail server.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@plorigo.local
