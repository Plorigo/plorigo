# Copy to .env and fill in. NEVER commit a real .env (see .gitignore).

# 32-byte key, base64-encoded. Generate with: openssl rand -base64 32
APP_MASTER_KEY=

# PostgreSQL connection string used by the control plane and goose migrations.
DATABASE_URL=postgres://plorigo:plorigo@localhost:5432/plorigo?sslmode=disable

# HTTP port the control plane listens on.
PORT=8080

# "production" makes session cookies Secure (HTTPS-only). Anything else = dev.
PLORIGO_ENV=dev

# Dashboard origin used to build links in emails (verification, password reset).
# In dev the dashboard runs on the Vite server; in the single binary it is the
# control plane's own public URL.
PLORIGO_BASE_URL=http://localhost:5173

# Control-plane public API origin used by the server agent install command.
# In dev this is the Go control plane; in the single-binary deployment it can match
# PLORIGO_BASE_URL.
PLORIGO_PUBLIC_URL=http://localhost:8080

# Auth policy. Open registration lets anyone sign up; when false only the first
# (bootstrap) user and invited users may. Email verification is optional.
PLORIGO_ALLOW_OPEN_REGISTRATION=true
PLORIGO_REQUIRE_EMAIL_VERIFICATION=false

# SMTP for transactional email. Leave SMTP_HOST empty to log emails (with their
# links) instead of sending — fine for local/self-host without a mail server.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@plorigo.local

# ---- GitHub source integration (optional) ----
# Connect repositories for build-from-Git deploys and pull-request previews. All of these are
# SERVER config (never per-workspace); when unset the dashboard hides the matching connect
# option. Full setup walkthrough: docs/architecture/sources.md.
#
# GitHub OAuth App — lets a workspace connect an account to browse/import repos (discovery).
# Its callback URL must be {PLORIGO_BASE_URL}/api/github/callback. The scope defaults to "repo"
# (read/write to ALL the user's repos); set GITHUB_OAUTH_SCOPES=public_repo to narrow it.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_SCOPES=repo
#
# GitHub App — the narrower, per-repo path for PRIVATE-repo deploys + webhook-driven PR previews.
# Create an App (permissions: Contents read, Metadata read, Pull requests read; webhook URL
# {PLORIGO_BASE_URL}/api/github/webhook, secret = GITHUB_WEBHOOK_SECRET, subscribed to Pull
# request events), generate a private key, then set these. GITHUB_APP_PRIVATE_KEY is the PEM
# contents (a single-line value with \n escapes, or your orchestrator's multi-line/file form).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=
# A pull-request preview is torn down after this many hours (0 disables the expiry sweep).
# PLORIGO_PREVIEW_TTL_HOURS=72

# ---- Local dev login (optional, your machine only) ----
# `make seed` creates/refreshes a verified local login so you can skip registration.
# It is DEV-ONLY (refuses unless PLORIGO_ENV=dev) and never runs in production or as
# part of the server — run it yourself once your dev DB is up:
#   make seed                                   # dev@plorigo.local / devpassword
#   make seed SEED_EMAIL=you@x.com SEED_PASSWORD=secret123
# To prefill the dashboard login form in dev, put these in apps/web/.env.local
# (gitignored) — they are stripped from production builds:
#   VITE_DEV_EMAIL=dev@plorigo.local
#   VITE_DEV_PASSWORD=devpassword
